# Copie este arquivo para ".env" na raiz do projeto se quiser
# customizar valores ao rodar `docker compose up`. Nenhuma dessas
# variáveis é obrigatória — todas têm um valor padrão funcional já
# definido no docker-compose.yml.

# Senha do usuário root do MySQL (container)
MYSQL_ROOT_PASSWORD=memora_root_pw

# Chave secreta usada para assinar os tokens JWT — troque em produção real
JWT_SECRET=memora-leia-edition-chave-secreta-trocar-em-producao-32bytes+

# Provider de IA ativo: MOCK (padrão, não exige chave) | GEMINI | GROQ | OPENROUTER
MEMORA_IA_PROVIDER=MOCK #se quiser usar gemini COLOQUE GEMINI
GEMINI_API_KEY=SUACHAVEVAIAQUI
GROQ_API_KEY=
OPENROUTER_API_KEY=

# SMTP para recuperação de senha por e-mail (opcional — sem isso, o
# token de recuperação só fica registrado no log da aplicação)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# URL base usada em links gerados pela aplicação (e-mails, etc.)
APP_BASE_URL=http://localhost:8080
